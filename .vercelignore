# Keep Vercel deployments focused on the B-end web/api runtime only.
artifacts/**
dist/**
playwright-tests/**
tmp/**
third_party/**
openclaw-relay/**

# VCS and dependencies are not needed in upload payload.
.git/**
node_modules/**
**/node_modules/**

# Local and generated artifacts.
*.apk
*.aab
*.dex
*.iml
*.log
*.tmp
*.hprof

# Binary documents and media not needed for deployment.
*.pptx
*.pdf
*.docx
*.zip
