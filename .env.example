# Lumi Agent Simulator - Environment Variables
# Copy this file to .env.local and fill in your API keys

# ============================================================================
# Required: OpenAI API Key (for Live Search / web_search tool)
# ============================================================================
# Get your key from: https://platform.openai.com/api-keys
# On Vercel: Set via Project Settings → Environment Variables
OPENAI_API_KEY=sk-proj-your-key-here

# ============================================================================
# Required: Google Gemini API Key (for main AI reasoning)
# ============================================================================
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here
# OpenClaw relay default model (Gemini 3.1 Pro)
OPENCLAW_GEMINI_MODEL=gemini-3.1-pro-preview
# Optional: fallback chain if 3.1 Pro is unavailable for the current key/region
OPENCLAW_GEMINI_FALLBACK_MODELS=gemini-3-pro-preview,gemini-3-flash-preview,gemini-2.5-pro,gemini-2.5-flash
# Optional: in-repo OpenClaw submodule path for local relay
# OPENCLAW_SUBMODULE_DIR=/absolute/path/to/lumi-agent-simulator/third_party/openclaw
# Optional: OpenClaw workspace root (defaults to <repo>/.openclaw/workspace in startup scripts)
# OPENCLAW_WORKSPACE_DIR=/absolute/path/to/lumi-agent-simulator/.openclaw/workspace
# Optional: override OpenClaw command used by relay
# OPENCLAW_BIN="node /absolute/path/to/third_party/openclaw/openclaw.mjs"

# ============================================================================
# Optional: Tavily API Key (for web search fallback)
# ============================================================================
TAVILY_API_KEY=tvly-your-key-here

# ============================================================================
# Optional but Recommended: SerpApi Key (for realtime flight prices)
# ============================================================================
# Get your key from: https://serpapi.com/
# Browser runtime can use VITE_SERPAPI_KEY, server runtime can use SERPAPI_KEY.
VITE_SERPAPI_KEY=your-serpapi-key-here
SERPAPI_KEY=your-serpapi-key-here

# ============================================================================
# Optional: Amadeus Self-Service API (third structured realtime flight source)
# ============================================================================
# Get your keys from: https://developers.amadeus.com/
VITE_AMADEUS_CLIENT_ID=your-amadeus-client-id
VITE_AMADEUS_CLIENT_SECRET=your-amadeus-client-secret
# Optional override, defaults to sandbox:
# VITE_AMADEUS_BASE_URL=https://test.api.amadeus.com

# ============================================================================
# Optional: Reddit API (for Promotion Agent)
# ============================================================================
# Create a Reddit app at: https://www.reddit.com/prefs/apps
# Select "script" type for personal use
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password
REDDIT_USER_AGENT=lumi-promotion-agent/1.0
# Browser runtime variants (for Vite):
VITE_REDDIT_CLIENT_ID=your-reddit-client-id
VITE_REDDIT_CLIENT_SECRET=your-reddit-client-secret
VITE_REDDIT_USERNAME=your-reddit-username
VITE_REDDIT_PASSWORD=your-reddit-password
VITE_REDDIT_USER_AGENT=lumi-promotion-agent/1.0

# ============================================================================
# Environment
# ============================================================================
# Set to 'production' on Vercel deployment
NODE_ENV=development
