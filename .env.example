# Lumi Agent Simulator - Environment Variables
# Copy this file to .env.local and fill in your API keys

# ============================================================================
# Required: OpenAI API Key (for Live Search / web_search tool)
# ============================================================================
# Get your key from: https://platform.openai.com/api-keys
# On Vercel: Set via Project Settings → Environment Variables
OPENAI_API_KEY=sk-proj-your-key-here

# ============================================================================
# Required: Google Gemini API Key (for main AI reasoning)
# ============================================================================
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# ============================================================================
# Optional: Tavily API Key (for web search fallback)
# ============================================================================
TAVILY_API_KEY=tvly-your-key-here

# ============================================================================
# Environment
# ============================================================================
# Set to 'production' on Vercel deployment
NODE_ENV=development
