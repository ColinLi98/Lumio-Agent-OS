<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:centerColor="#102A58"
                android:endColor="#1A3F7A"
                android:startColor="#050E28" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item
        android:insetLeft="10dp"
        android:insetTop="10dp"
        android:insetRight="10dp"
        android:insetBottom="10dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="44dp"
                android:startColor="#A34FF5FF"
                android:centerColor="#5B8BFF"
                android:endColor="#104B7BFF" />
            <stroke
                android:width="1dp"
                android:color="#7EA9FF" />
        </shape>
    </item>

    <item
        android:insetLeft="18dp"
        android:insetTop="18dp"
        android:insetRight="18dp"
        android:insetBottom="18dp">
        <bitmap
            android:gravity="center"
            android:src="@drawable/lumi_logo" />
    </item>
</layer-list>
