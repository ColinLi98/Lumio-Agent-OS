<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_screen"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls"
        android:scrollbars="vertical"
        android:paddingStart="22dp"
        android:paddingTop="26dp"
        android:paddingEnd="22dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chat_card"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_logo_tile"
                        android:padding="3dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:contentDescription="Lumi Logo"
                            android:scaleType="centerInside"
                            android:src="@drawable/lumi_logo" />
                    </FrameLayout>

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_online_dot" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lumi Agent"
                        android:textColor="#F3FAFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Online · Super Agent"
                        android:textColor="#7E9DC5"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:background="#1D355E" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="18dp"
                android:paddingBottom="18dp">

                <FrameLayout
                    android:layout_width="78dp"
                    android:layout_height="78dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_logo_glow" />

                    <FrameLayout
                        android:layout_width="62dp"
                        android:layout_height="62dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_logo_tile"
                        android:padding="6dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:contentDescription="Lumi Main Logo"
                            android:scaleType="centerInside"
                            android:src="@drawable/lumi_logo" />
                    </FrameLayout>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Lumi Agent Chat"
                    android:textColor="#EAF4FF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chatSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="In any app, long-press Space to activate Agent Mode&#10;Your prompt will generate suggested replies automatically"
                    android:textColor="#95AFCC"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/activeModuleLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="12dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="5dp"
                    android:text="Current module: Chat"
                    android:textColor="#CFE2FF"
                    android:textSize="12sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/quickFlight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="14dp"
                        android:paddingTop="9dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="9dp"
                        android:text="⚡ Flights &amp; Hotels"
                        android:textColor="#CEE0FF"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/quickFood"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="14dp"
                        android:paddingTop="9dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="9dp"
                        android:text="⚡ Restaurant Picks"
                        android:textColor="#CEE0FF"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/quickLix"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="14dp"
                        android:paddingTop="9dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="9dp"
                        android:text="⚡ LIX Close"
                        android:textColor="#CEE0FF"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/quickAgent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="14dp"
                        android:paddingTop="9dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="9dp"
                        android:text="⚡ Agent Orchestration"
                        android:textColor="#CEE0FF"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/quickAvatar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="14dp"
                        android:paddingTop="9dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="9dp"
                        android:text="⚡ Twin Avatar"
                        android:textColor="#CEE0FF"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/quickDestiny"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="14dp"
                        android:paddingTop="9dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="9dp"
                        android:text="⚡ Destiny Navigation"
                        android:textColor="#CEE0FF"
                        android:textSize="13sp" />
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input_container"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="10dp">

                <EditText
                    android:id="@+id/promptInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Enter a prompt..."
                    android:imeOptions="actionSend"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textColor="#EAF4FF"
                    android:textColorHint="#5B7BA6"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/sendButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_send_button"
                    android:gravity="center"
                    android:text="➤"
                    android:textColor="#BBD8FF"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/resultPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⌂&#10;Home"
            android:textColor="#7C9ABF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/navChat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="◉&#10;Chat"
            android:textColor="#6CC8FF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/navLix"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="▣&#10;LIX"
            android:textColor="#7C9ABF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/navAgent"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="◎&#10;Agent"
            android:textColor="#7C9ABF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/navAvatar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="◌&#10;Avatar"
            android:textColor="#7C9ABF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/navRoute"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="➤&#10;Navigation"
            android:textColor="#7C9ABF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⚙&#10;Settings"
            android:textColor="#7C9ABF"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
