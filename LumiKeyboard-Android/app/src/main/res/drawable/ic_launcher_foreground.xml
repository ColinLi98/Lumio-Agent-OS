<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:gravity="center"
        android:height="88dp"
        android:width="88dp">
        <shape android:shape="oval">
            <gradient
                android:centerColor="#5B8BFF"
                android:endColor="#104B7BFF"
                android:gradientRadius="44dp"
                android:startColor="#A34FF5FF"
                android:type="radial" />
            <stroke
                android:width="1dp"
                android:color="#7EA9FF" />
        </shape>
    </item>

    <item
        android:gravity="center"
        android:height="64dp"
        android:width="64dp">
        <bitmap
            android:gravity="center"
            android:src="@drawable/lumi_logo" />
    </item>
</layer-list>
